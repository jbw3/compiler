const TheStruct = struct
{
    string str,
    num i32 = 0,
};

fun a_function(x i32, p &i32)
{
    var s = TheStruct:
    {
        string = "abc\\\"\n\r\t©ℼ😎",
        num = x,
    };

    var sum i32 = 0;
    for i in 0..s.num
    {
        sum += i;
        if i >= 100
        {
            break;
        }
    }
    *p = sum;

    if x < 1
    {
        *p += 1;
    }
    elif x < 2
    {
        *p *= 2;
    }
    else
    {
        *p += 12;
    }

    while test_value(x)
    {
        *p *= 2;
    }

    var less bool = false;
    var float f64 = 1.2 * @pi + ef();
    if float < 20.2
    {
        less = true;
    }

    var array []f64 = [
        float,
        @cast(f64, *p),
        @cast(f64, s.num),
    ];

    var a2 []u8 = [4; 7];

    unchecked
    {
        var addr u64 = a2[2];
        var ptr &i32 = @intToPtr(&i32, addr);
    }

    multiple_params(1.2, p3 = less, p1 = 17, p2 = a2[0]);
}

fun test_value(x i32) bool
{
    return x < 4;
}

extern fun ef() f64;

